# Neon PostgreSQL connection string (use the pooled endpoint)
# Get this from https://console.neon.tech → your project → Connection Details
# Tip: remove channel_binding=require; add pgbouncer=true for Prisma + Neon pooler
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Used only by the seed script to create the admin account
ADMIN_PASSWORD="changeme"

# Cloudflare R2 — product images, logo, and hero videos
# Create a bucket, enable public access (or custom domain), and create an API token
# with Object Read & Write for that bucket.
#
# For hero video uploads (direct browser → R2), configure CORS on the bucket, e.g.:
#   AllowedOrigins: your app origin(s)
#   AllowedMethods: PUT, GET, HEAD
#   AllowedHeaders: *
#   ExposeHeaders: ETag
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="hoilamo-products"
# Public base URL, e.g. https://pub-xxxxx.r2.dev or https://images.yourdomain.com
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
